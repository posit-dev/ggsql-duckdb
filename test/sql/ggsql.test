# name: test/sql/ggsql.test
# description: test ggsql extension
# group: [sql]
#
# Run with GGSQL_NO_OPEN_BROWSER=1 in the environment to prevent the Rust side
# from launching a browser tab for each test query.

# Before the extension loads, ggsql('...') is an unknown function
statement error
SELECT ggsql('VISUALISE FROM ggsql:penguins DRAW point');
----
Catalog Error

require ggsql

# Parser extension must decline a statement whose only use of VISUALISE is inside a
# string literal. If it claimed it, we'd get an error from the ggsql pipeline.
query I
SELECT 'I love VISUALISE' AS s;
----
I love VISUALISE

# Parser extension must also decline when VISUALISE appears in a line comment.
query I
SELECT 1 AS x; -- VISUALISE would be nice
----
1

# --------------------------------------------------------------------------------
# Default mode is 'silent' — table-function form emits zero visible rows even
# though the ggsql pipeline ran (the plot has been served to the browser tab).
# --------------------------------------------------------------------------------
query I
SELECT * FROM (VALUES (1, 10), (2, 20)) AS t(x, y) VISUALISE x, y DRAW point;
----

# Explicit 'url' mode — returns the plot URL.
statement ok
SET ggsql_output = 'url';

query I
SELECT ggsql('SELECT 1 AS x, 2 AS y VISUALISE x, y DRAW point')
  LIKE 'http://127.0.0.1:%';
----
true

# 'spec' mode — returns the vega-lite JSON as a VARCHAR, no server, no browser.
statement ok
SET ggsql_output = 'spec';

query I
SELECT ggsql('SELECT 1 AS x, 2 AS y VISUALISE x, y DRAW point')
  LIKE '%vega-lite%';
----
true

# 'html' mode — returns a self-contained HTML document with inlined vega bundles.
statement ok
SET ggsql_output = 'html';

query I
SELECT ggsql('SELECT 1 AS x, 2 AS y VISUALISE x, y DRAW point')
  LIKE '<!doctype html>%';
----
true

# The inlined bundle should make the HTML payload much larger than the raw spec.
# (~800 KB for the JS bundles; a bare spec is < 5 KB.)
query I
SELECT length(ggsql('SELECT 1 AS x, 2 AS y VISUALISE x, y DRAW point')) > 500000;
----
true

# Unknown mode values should surface a clear error rather than silently falling back.
statement ok
SET ggsql_output = 'nope';

statement error
SELECT ggsql('SELECT 1 AS x, 2 AS y VISUALISE x, y DRAW point');
----
unrecognised value

# Reset so the default path keeps working after a setting change.
statement ok
RESET ggsql_output;

# After RESET we're back to the silent default — parser-extension form emits no rows.
query I
SELECT 1 AS x, 2 AS y VISUALISE x, y DRAW point;
----
