# name: test/sql/ggsql.test
# description: test ggsql extension
# group: [sql]
#
# Run with GGSQL_NO_OPEN_BROWSER=1 in the environment to prevent the Rust side
# from launching a browser tab for each test query.

# Before the extension loads, ggsql('...') is an unknown function
statement error
SELECT ggsql('VISUALISE FROM ggsql:penguins DRAW point');
----
Catalog Error

require ggsql

# Parser extension must decline a statement whose only use of VISUALISE is inside a
# string literal. If it claimed it, we'd get an error from the ggsql pipeline.
query I
SELECT 'I love VISUALISE' AS s;
----
I love VISUALISE

# Parser extension must also decline when VISUALISE appears in a line comment.
query I
SELECT 1 AS x; -- VISUALISE would be nice
----
1

# Scalar form: running a ggsql query returns a URL to the locally-served plot.
query I
SELECT ggsql('SELECT * FROM (VALUES (1, 10), (2, 20), (3, 30)) AS t(x, y) VISUALISE x, y DRAW point')
  LIKE 'http://127.0.0.1:%';
----
true

# Parser-extension form: typing the ggsql query directly parses and executes without
# error. We can't literal-match the URL row (port is random), so we just assert that
# the pipeline runs end-to-end.
statement ok
SELECT * FROM (VALUES (1, 10), (2, 20), (3, 30)) AS t(x, y) VISUALISE x, y DRAW point;
